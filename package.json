{
  "name": "qwen-gate",
  "version": "0.2.0",
  "description": "OpenAI-compatible API gateway for Qwen models — drop-in replacement for /v1/chat/completions with multi-account rotation, tool calling, streaming SSE, and web dashboard",
  "main": "index.js",
  "bin": {
    "qg": "./bin/qg",
    "qwengate": "./bin/qg",
    "qwen-gate": "./bin/qg"
  },
  "scripts": {
    "postinstall": "node scripts/setup.js || exit 0",
    "build": "tsc -p tsconfig.build.json",
    "start": "npx tsx src/index.tsx 2>&1 | grep --line-buffered -v 'injected env'",
    "dev": "npx tsx src/index.tsx",
    "start:firefox": "npx tsx src/index.tsx --browser=firefox",
    "start:chrome": "npx tsx src/index.tsx --browser=chrome",
    "start:edge": "npx tsx src/index.tsx --browser=edge",
    "setup": "node scripts/setup.js",
    "test": "tsx --test src/**/*.test.ts",
    "qg": "tsx src/cli.ts",
    "qg:restart": "tsx src/cli.ts restart"
  },
  "keywords": ["qwen", "api-gateway", "openai-compatible", "playwright", "hono", "typescript", "sse", "tool-calling", "multi-account", "browser-automation", "proxy", "llm-gateway", "openai-proxy", "qwen-ai", "chat-completions", "function-calling"],
  "author": "Youssef Adel",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "cloakbrowser": "^0.3.31",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "typescript": "^6.0.3"
  },
  "type": "module"
}
