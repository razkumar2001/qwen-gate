# QwenProxy Configuration

# Port for the proxy server (default: 26405)
PORT=26405

# API key to protect endpoints (optional — leave empty for no auth)
API_KEY=

# ── Qwen Credentials ─────────────────────────────────────────────

# Cooldown when an account gets rate-limited (ms, default: 120000 = 2 min)
# RATE_LIMIT_COOLDOWN_MS=120000

# Check account status at runtime: GET /accounts


# Browser engine: chromium (default), firefox, chrome, edge
BROWSER=chromium

# ── Output control ────────────────────────────────────────────────
# Disable tool call parsing — raw Qwen output passes through unchanged
# TOOL_CALLING=false

# Disable content filtering — thinking/XML stripping and space collapsing
# Set this if output has missing spaces/newlines from aggressive filtering
# CONTENT_FILTER=false

# Skip backtick stripping in the parser (only applies when TOOL_CALLING=true)
# CLEAN_OUTPUT=false

# Force streaming mode: 'true' = always stream, 'false' = never stream
# STREAMING=true



# ── Debug / Logging ──────────────────────────────────────────────
# Enable debug logging — shows raw Qwen chunks vs processed output
# DEBUG=true
