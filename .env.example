# QwenProxy Configuration

# Port for the proxy server (default: 26405)
PORT=26405

# API key to protect endpoints (optional — leave empty for no auth)
API_KEY=

# ── Qwen Credentials ─────────────────────────────────────────────

# Cooldown when an account gets rate-limited (ms, default: 120000 = 2 min)
# RATE_LIMIT_COOLDOWN_MS=120000

# Check account status at runtime: GET /accounts


# Browser engine: chromium (default), firefox, chrome, edge
BROWSER=chromium

# ── Output control ────────────────────────────────────────────────
# Disable tool call parsing — raw Qwen output passes through unchanged
# TOOL_CALLING=false

# Disable content filtering — thinking/XML stripping and space collapsing
# Set this if output has missing spaces/newlines from aggressive filtering
# CONTENT_FILTER=false

# Skip backtick stripping in the parser (only applies when TOOL_CALLING=true)
# CLEAN_OUTPUT=false

# Force streaming mode: 'true' = always stream, 'false' = never stream
# STREAMING=true

# ── Tool Call Limiting ────────────────────────────────────────────
# Safety net: max tool calls extracted per response (default: 10).
# The primary mechanism is the system prompt teaching the AI to self-limit
# (see rule 7 in TOOL_FORMAT_INSTRUCTION). This env var is a circuit breaker
# that rejects responses exceeding the limit.
# Values: 1 (strictest) to 25 (practically no limit). Default 10.
# MAX_TOOL_CALLS_PER_RESPONSE=10

# Max cumulative tool calls per user request across all executor loop turns (default: 10).
# This is the final hard stop — once reached, the executor returns immediately.
# Works alongside MAX_TOOL_CALLS_PER_RESPONSE (per-chunk) as defense in depth.
# Values: 1-25. Default 10 balances flexibility with attention safety.
# MAX_TOOL_CALLS_PER_REQUEST=10

# Maximum execution loop turns (default: 3)
# Controls how many LLM round-trips the executor runs before forcing a response.
# Lower values prevent runaway tool loops. Only used when tool execution loop
# is enabled (self-hosted tool execution, not the streaming proxy).
# MAX_EXECUTION_TURNS=3

# ── Debug / Logging ──────────────────────────────────────────────
# Enable debug logging — shows raw Qwen chunks vs processed output
# DEBUG=true
