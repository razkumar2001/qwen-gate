# QwenProxy Configuration

# Port for the proxy server (default: 80)
PORT=80

# API key to protect endpoints (optional — leave empty for no auth)
API_KEY=

# Qwen credentials for automatic login (used by both browser-based and direct API auth)
QWEN_EMAIL=
QWEN_PASSWORD=

# Auth token management (optional — defaults work for most cases)
# AUTH_TOKEN_MAX_AGE_MS=3600000    # How long a token lasts before forced re-login (default: 1h)
# AUTH_REFRESH_BEFORE_MS=300000    # How long before expiry to trigger refresh (default: 5min)
# AUTH_REFRESH_DELAY_MS=1000       # Retry delay on auth failure (default: 1s)

# Browser engine: chromium (default), firefox, chrome, edge
BROWSER=chromium
