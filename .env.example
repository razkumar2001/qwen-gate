# ── Qwen Gate Configuration ──────────────────────────────────────
# Copy this file to .env and edit values as needed.
# All variables shown with their DEFAULTS — uncomment only what you need to change.

# ── Server ────────────────────────────────────────────────────────

# Proxy server port
PORT=26405

# Bind host (use '0.0.0.0' to expose on all interfaces)
HOST=localhost

# API key to protect endpoints (leave empty for no auth)
# Clients send as: Authorization: Bearer <API_KEY>
API_KEY=

# ── Browser Engine ───────────────────────────────────────────────

# Browser backend: chromium (default) | firefox | chrome | edge
# 'chromium' ships with Playwright. 'chrome' / 'edge' use the system install.
BROWSER=chromium

# ── Qwen Account Management ──────────────────────────────────────

# Accounts are managed via the /accounts API or data/accounts.json.
# There is NO email/password env var — all accounts live in persistent storage.

# Cooldown duration when an account is rate-limited (ms, default: 2 minutes)
RATE_LIMIT_COOLDOWN_MS=120000

# Timeout for Qwen API fetch requests (ms, default: 30 seconds)
QWEN_FETCH_TIMEOUT_MS=30000

# Refresh the auth token this many ms before it expires (default: 300000 = 5 min)
# AUTH_REFRESH_BEFORE_MS=300000

# Force a token refresh when the token is older than this (ms, default: 28800000 = 8h)
# AUTH_TOKEN_MAX_AGE_MS=28800000

# Delete chat sessions on Qwen's backend when the pool releases them (default: true).
# Set to 'false' to keep history on Qwen's side for debugging.
# DELETE_SESSION=true

# ── Echo Detector ────────────────────────────────────────────────

# Enable the streaming echo detector (default: true).
# When enabled, if the model repeats tool output verbatim mid-stream,
# the connection is dropped and the SDK retries on a fresh session.
# Set to 'false' to disable this behavior entirely.
# ECHO_DETECTOR=true

# Echo detection sensitivity (default: 0.9).
# Bidirectional shingle containment threshold. Higher = stricter (fewer detections).
# Range 0.0-1.0. At 0.9, the output must share 90%+ of 5-gram shingles with a
# tool result line in both directions to trigger.
# ECHO_JACCARD_THRESHOLD=0.9

# Minimum line length in chars for echo comparison (default: 20).
# Shorter lines have too few shingles for reliable matching.
# ECHO_MIN_LINE_LENGTH=20

# Minimum unique shingles required for echo comparison (default: 8).
# Lines with fewer distinguishing 5-grams are skipped.
# ECHO_MIN_UNIQUE_SHINGLES=8

# ── Output / Pipeline Control ────────────────────────────────────

# Tool calling: parse tool invocations and apply schema validation (default: true)
# Disable to pass Qwen's raw output through unchanged.
# TOOL_CALLING=true

# Maximum number of identical (tool, args) calls allowed per response before the spam guard kicks in.
# MAX_TOOL_CALLS_PER_RESPONSE=3

# Content filtering: strip tool-call artifacts, XML leaks, thinking blocks (default: true)
# CONTENT_FILTER=true

# Clean output: strip backticks and collapse whitespace in parser output (default: true)
# Only applies when TOOL_CALLING=true.
# CLEAN_OUTPUT=true

# Force streaming mode on/off regardless of client request body
# STREAMING=true | false
# NON_STREAMING=true

# ── Dashboard (Astro Frontend) ───────────────────────────────────

# Enable the web dashboard at /dashboard (default: true)
# DASHBOARD=true

# Astro dev server port (default: 4321)
# ASTRO_PORT=4321

# ── Logging ──────────────────────────────────────────────────────

# Enable debug logging: raw Qwen chunks vs processed output
# DEBUG=true

# Debug streaming pipeline only (without full DEBUG noise)
# DEBUG_STREAM=true

# Log level: debug | info | warn | error (auto-set to 'debug' if DEBUG=true)
# LOG_LEVEL=info

# Log format: 'json' for JSON lines, otherwise human-readable
# LOG_FORMAT=json

# Max visible entries in the request log table (default: 20)
# LOG_MAX_ENTRIES=20

# ── Upstream Retry (Qwen API retries) ───────────────────────────

# Master switch for upstream retries (default: true)
# RETRY_ENABLED=true

# Retry tuning for upstream Qwen calls (backoff with jitter)
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY_MS=1000
# RETRY_MAX_DELAY_MS=30000
# RETRY_BACKOFF_MULTIPLIER=2

# ── Testing (internal) ──────────────────────────────────────────

# Mock Playwright — used only by the test suite, not for production
# TEST_MOCK_PLAYWRIGHT=true

# Mock session ID returned when TEST_MOCK_PLAYWRIGHT is set
# TEST_SESSION_ID=mock-session
